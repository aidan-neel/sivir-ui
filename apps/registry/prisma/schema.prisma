// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

// URLs live in prisma.config.ts (Prisma 7+).
// - Runtime queries: src/lib/prisma.ts reads DATABASE_URL (Supabase transaction pooler, port 6543).
// - Migrations: prisma.config.ts → DIRECT_URL (Supabase session/direct, port 5432).
datasource db {
  provider = "postgresql"
}

model Theme {
  id          String   @id @default(cuid())
  version     Int      @default(2)
  slug        String   @unique
  name        String
  description String
  publisher   String?
  brand       String
  neutral     String
  radius      String
  density     String
  motionFeel  String
  fontSans    String
  fontMono    String
  fontHeader  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

/// Tombstone for built-in default themes that an admin has chosen to hide.
/// Listing the registry skips defaults whose slug appears here.
model HiddenDefault {
  slug     String   @id
  hiddenAt DateTime @default(now())
}
