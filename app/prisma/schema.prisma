generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Theme {
  id        Int    @id @default(autoincrement())
  name      String @unique
  css       String
  favorites Int @default(0)
  likes     Int @default(0)
  publisher String @default("anonymous")
}
