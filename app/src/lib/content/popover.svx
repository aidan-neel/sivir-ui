---
title: Popover
description: Displays a popup element that appears near a trigger.
component: true
source: https://github.com/aidan-neel/ui/tree/main/registry/ui/default/popover
---

<script>
    import { ComponentPreview, CodeBlock, CodeSnippet, ExportItem, APIReference } from '$lib/components/docs';
    import { Button } from '$lib/ui/components/button';
    import { Input } from '$lib/ui/components/input';
    import * as Popover from '$lib/ui/components/popover';
</script>

<h1 class="py-2">
    Import
</h1>

<p class="py-2">
    Popover exports 3 components
</p>

<ExportItem title="Root">The root component that manages the popover.</ExportItem>
<ExportItem title="Trigger">The element that opens the popover when interacted with.</ExportItem>
<ExportItem title="Content">The content container that appears within the popover.</ExportItem>

<h1 class="py-6">
    Example
</h1>

<ComponentPreview code={`<script lang="ts">
    import * as Popover from "$lib/ui/components/popover";
</script>\n
<Popover.Root>
