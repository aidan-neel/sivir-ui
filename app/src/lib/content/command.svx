<h1 class="py-6 h1">API Reference</h1>

<div class="flex flex-col gap-10">
	<APIReference
		title="Command"
		component="Root"
		description="Owns the open state and registered command items."
		items={[
			{ property: "open", type: "boolean", description: "Optional open state for the command palette.", defaults: "false" },
			{ property: "stateKey", type: "string", description: "Optional custom state key for sharing command state." },
			{ property: "children", type: "Snippet", description: "Trigger, content, search, and items." }
		]}
	/>

	<APIReference
		title="Command"
		component="Trigger"
		description="Button that opens the command palette."
		items={[
			{ property: "children", type: "Snippet", description: "Trigger content." },
			{ property: "variant", type: "ButtonVariant", description: "Button variant for the trigger." },
			{ property: "class", type: "string", description: "Additional trigger classes." }
		]}
	/>

	<APIReference
		title="Command"
		component="Content"
		description="Centered modal palette surface."
		items={[
			{ property: "allowClickOutside", type: "boolean", description: "Whether clicking outside dismisses the palette.", defaults: "true" },
			{ property: "class", type: "string", description: "Additional classes for the palette." }
		]}
	/>

	<APIReference
		title="Command"
		component="Search"
		description="Input used to filter command items."
		items={[
			{ property: "threshold", type: "number", description: "Fuse.js match threshold.", defaults: "0.5" },
			{ property: "placeholder", type: "string", description: "Native input placeholder text." }
		]}
	/>

	<APIReference
		title="Command"
		component="Item"
		description="Single command action."
		items={[
			{ property: "name", type: "string", description: "Search index text for the command item." },
			{ property: "callback", type: "() => void", description: "Function fired when the item is selected." },
			{ property: "children", type: "Snippet", description: "Rendered item content." },
			{ property: "class", type: "string", description: "Additional item classes." }
		]}
	/>

	<APIReference
		title="Command"
		component="Group"
		description="Optional labeled grouping inside the results list."
		items={[
			{ property: "heading", type: "string", description: "Section heading shown above the grouped items." },
			{ property: "children", type: "Snippet", description: "Command items inside the group." }
		]}
	/>
</div>
