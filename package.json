{
	"name": "sivir",
	"private": true,
	"type": "module",
	"packageManager": "bun@1.3.11",
	"engines": {
		"bun": ">=1.3.11"
	},
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"overrides": {
		"@hono/node-server": "1.19.13",
		"brace-expansion": "5.0.7",
		"cookie": "1.1.1",
		"hono": "4.12.25",
		"tar": "7.5.20",
		"undici": "7.28.0"
	},
	"scripts": {
		"dev": "turbo run dev",
		"build": "turbo run build",
		"generate": "turbo run generate",
		"check": "turbo run check",
		"lint": "turbo run lint",
		"test": "turbo run test",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"prepare": "lefthook install"
	},
	"devDependencies": {
		"lefthook": "^1.13.6",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"turbo": "^2.10.0"
	}
}
