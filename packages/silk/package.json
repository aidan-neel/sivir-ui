{
	"name": "@silk/ui",
	"version": "0.0.0",
	"type": "module",
	"license": "MIT",
	"publishConfig": {
		"access": "public"
	},
	"sideEffects": [
		"**/*.css"
	],
	"files": [
		"dist"
	],
	"svelte": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js",
			"default": "./dist/index.js"
		},
		"./package.json": "./package.json",
		"./ui.css": "./dist/ui.css",
		"./utils": {
			"types": "./dist/utils.d.ts",
			"svelte": "./dist/utils.js",
			"default": "./dist/utils.js"
		},
		"./themes/presets": {
			"types": "./dist/themes/presets.d.ts",
			"default": "./dist/themes/presets.js"
		},
		"./internals/transition": {
			"types": "./dist/internals/transition.d.ts",
			"default": "./dist/internals/transition.js"
		},
		"./internals/state.svelte.ts": {
			"types": "./dist/internals/state.svelte.d.ts",
			"svelte": "./dist/internals/state.svelte.js",
			"default": "./dist/internals/state.svelte.js"
		},
		"./_manifest/types": {
			"types": "./dist/_manifest/types.d.ts",
			"default": "./dist/_manifest/types.js"
		},
		"./components/_internal/overlay": {
			"types": "./dist/components/_internal/overlay/index.d.ts",
			"svelte": "./dist/components/_internal/overlay/index.js",
			"default": "./dist/components/_internal/overlay/index.js"
		},
		"./components/button": {
			"types": "./dist/components/button/index.d.ts",
			"svelte": "./dist/components/button/index.js",
			"default": "./dist/components/button/index.js"
		},
		"./components/input/variants": {
			"types": "./dist/components/input/variants.d.ts",
			"default": "./dist/components/input/variants.js"
		},
		"./components/modal": {
			"types": "./dist/components/modal/index.d.ts",
			"svelte": "./dist/components/modal/index.js",
			"default": "./dist/components/modal/index.js"
		},
		"./components/popover": {
			"types": "./dist/components/popover/index.d.ts",
			"svelte": "./dist/components/popover/index.js",
			"default": "./dist/components/popover/index.js"
		}
	},
	"scripts": {
		"build": "svelte-package -i src -o dist",
		"check": "svelte-package -i src -o dist",
		"prepublishOnly": "svelte-package -i src -o dist",
		"lint": "prettier --check ."
	},
	"dependencies": {
		"@floating-ui/dom": "^1.7.6",
		"@lucide/svelte": "^1.7.0",
		"clsx": "^2.1.1",
		"fuse.js": "^7.1.0",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2"
	},
	"peerDependencies": {
		"@sveltejs/kit": "^2.0.0",
		"svelte": "^5.0.0",
		"tailwindcss": "^4.0.0"
	},
	"peerDependenciesMeta": {
		"@sveltejs/kit": {
			"optional": true
		}
	},
	"devDependencies": {
		"@sveltejs/kit": "^2.55.0",
		"@sveltejs/package": "^2.5.4",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"svelte": "^5.55.1",
		"tailwindcss": "^4.2.2",
		"typescript": "^5.9.3",
		"vite": "^8.0.3"
	}
}
