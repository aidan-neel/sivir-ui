{
	"name": "@sivir/ui",
	"version": "0.1.0",
	"description": "SvelteKit component library inspired by shadcn/ui. Svelte 5 + Tailwind v4.",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/aidan-neel/sivir-ui.git",
		"directory": "packages/sivir"
	},
	"homepage": "https://github.com/aidan-neel/sivir-ui#readme",
	"bugs": "https://github.com/aidan-neel/sivir-ui/issues",
	"keywords": [
		"svelte",
		"sveltekit",
		"components",
		"ui",
		"tailwind",
		"shadcn"
	],
	"type": "module",
	"sideEffects": [
		"**/*.css"
	],
	"files": [
		"src",
		"dist",
		"registry"
	],
	"bin": {
		"sivir": "dist/index.js"
	},
	"svelte": "./src/index.ts",
	"types": "./src/index.ts",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"svelte": "./src/index.ts",
			"default": "./src/index.ts"
		},
		"./ui.css": "./src/ui.css",
		"./brand-mark": "./src/brand-mark.svelte",
		"./utils": "./src/utils.ts",
		"./_manifest/types": "./src/_manifest/types.ts",
		"./internals/transition": "./src/internals/transition.ts",
		"./internals/*": "./src/internals/*",
		"./themes/presets": "./src/themes/presets.ts",
		"./themes/*": "./src/themes/*",
		"./components/input/variants": "./src/components/input/variants.ts",
		"./components/_internal/overlay": "./src/components/_internal/overlay/index.ts",
		"./components/*": "./src/components/*/index.ts"
	},
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build:registry": "bun scripts/build-registry.ts",
		"build": "bun run build:registry && bun build cli/index.ts --outdir dist --target node --banner '#!/usr/bin/env node'",
		"prepublishOnly": "bun run build",
		"check": "bun run check:cli && bun run check:components",
		"check:cli": "tsc --noEmit -p tsconfig.cli.json",
		"check:components": "svelte-check --tsconfig ./tsconfig.components.json",
		"test": "bun run build:registry && bun test",
		"sandbox": "bun scripts/sandbox.ts",
		"lint": "prettier --check ."
	},
	"dependencies": {
		"@floating-ui/dom": "^1.7.6",
		"@lucide/svelte": "^1.7.0",
		"cnfast": "^0.0.8",
		"fuse.js": "^7.1.0",
		"highlight.js": "^11.11.1",
		"slot-text": "^0.3.1",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2"
	},
	"peerDependencies": {
		"svelte": "^5.0.0",
		"tailwindcss": "^4.0.0"
	},
	"devDependencies": {
		"@clack/prompts": "^0.11.0",
		"bun-types": "latest",
		"commander": "^14.0.2",
		"picocolors": "^1.1.1",
		"svelte-check": "^4.4.6",
		"tailwindcss": "^4.2.2",
		"typescript": "^5.9.3"
	}
}
