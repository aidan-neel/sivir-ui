{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"lib": ["ES2022", "DOM", "DOM.Iterable"],
		"strict": true,
		"noEmit": true,
		"skipLibCheck": true,
		"allowJs": true,
		"checkJs": true,
		"allowImportingTsExtensions": true,
		"verbatimModuleSyntax": true,
		"baseUrl": ".",
		"paths": {
			"@sivir/ui": ["./src/index.ts"],
			"@sivir/ui/*": ["./src/*"]
		}
	},
	"include": ["check.d.ts", "src/**/*.ts", "src/**/*.svelte"]
}
